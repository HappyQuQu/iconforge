# 访问统计：默认已在 index.html 接入 Umami Cloud，一般无需再配置。
# 若改用自建 Umami 或 Plausible，可注释 index.html 中的 script，再启用下方变量。

# VITE_ANALYTICS_PROVIDER=umami
# VITE_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js
# VITE_UMAMI_WEBSITE_ID=d7aa1126-1498-4b64-83f1-15019f7de9c1

# VITE_ANALYTICS_PROVIDER=plausible
# VITE_PLAUSIBLE_DOMAIN=iconforge.qudev.top
# VITE_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# 页脚显示访问统计（需服务端代理 Umami API，不能把 API Key 写进前端）
# 本地开发：复制为 .env.local（VITE_STATS_URL=/api/stats），密钥放在 .dev.vars
# 线上 Cloudflare Pages：设置 UMAMI_API_KEY + VITE_STATS_URL=/api/stats 后重新部署
# 注意：Umami 脚本已允许 localhost；线上正式数据以 iconforge.qudev.top 为准
